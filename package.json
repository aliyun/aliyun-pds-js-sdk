{
  "name": "@ali/pds-js-sdk",
  "version": "1.4.0-beta.9",
  "type": "module",
  "description": "PDS SDK for javascript",
  "files": [
    "dist",
    "index.d.ts",
    "browser.d.ts"
  ],
  "main": "./dist/node/node-pds.umd.cjs",
  "module": "./dist/node/node-pds.js",
  "types": "./index.d.ts",
  "exports": {
    "./browser": {
      "import": "./dist/browser/aliyun-pds-js-sdk.js",
      "require": "./dist/browser/aliyun-pds-js-sdk.umd.cjs",
      "types": "./browser.d.ts"
    },
    ".": {
      "import": "./dist/node/node-pds.js",
      "require": "./dist/node/node-pds.umd.cjs",
      "types": "./index.d.ts"
    }
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "doc:node": "typedoc --tsconfig tsconfig.json --options typedoc-node.js",
    "doc:web": "typedoc --tsconfig tsconfig.json --options typedoc-web.js",
    "build:version": "node build.js",
    "build:node": "tsc --lib ES2020,DOM,DOM.Iterable  && vite build --config vite.config.node.js",
    "build:browser": "tsc --lib ES2020,DOM,DOM.Iterable && vite build --config vite.config.browser.js",
    "dts": "tsc --build tsconfig-dts.json",
    "build": "npm run build:version && npm run build:node && npm run build:browser && npm run dts",
    "format": "prettier --write 'lib/**/*.{js,mjs,ts}' 'tests/**/*.{js,mjs,ts}' examples/**/*.{js,vue,ts}",
    "test:node:ut": "vitest run --coverage --config vitest.config.node.ut.js",
    "test:browser:ut": "vitest run --coverage --config vitest.config.browser.ut.js",
    "test:node:ft": "npm run token && vitest run --coverage --config vitest.config.node.ft.js",
    "test:browser:ft": "npm run token && vitest run --coverage --config vitest.config.browser.ft.js",
    "token": "tsx tests/ft/bin/pre-test.js",
    "cov:node": "npm run token && vitest run --coverage --config vitest.config.node.cov.js && open-cli coverage/node/index.html",
    "cov:browser": "npm run token && vitest run --coverage --config vitest.config.browser.cov.js && open-cli coverage/browser/index.html",
    "cov:node2": "npm run token && vitest run --coverage --config vitest.config.node.cov.js",
    "cov:browser2": "npm run token && vitest run --coverage --config vitest.config.browser.cov.js"
  },
  "directories": {
    "test": "tests/"
  },
  "author": "guangchun.luo@alibaba-inc.com",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.18.0",
    "@vitest/browser": "1.6.0",
    "@vitest/coverage-istanbul": "1.6.0",
    "@vitest/ui": "1.6.0",
    "axios": "0.24.0",
    "cross-env": "7.0.3",
    "open-cli": "7.2.0",
    "playwright": "^1.53.2",
    "prettier": "3.3.3",
    "tsx": "3.14.0",
    "typedoc": "0.26.11",
    "typescript": "5.6.3",
    "uuid": "9.0.1",
    "vite": "4.5.5",
    "vite-plugin-commonjs-externals": "0.1.4",
    "vitest": "1.6.0"
  },
  "engines": {
    "node": ">=16.15.0"
  },
  "publishConfig": {
    "registry": "https://registry.anpm.alibaba-inc.com"
  },
  "repository": "git@gitlab.alibaba-inc.com:pds-next/pds-js-sdk.git",
  "dependencies": {
    "@types/node": "^25.3.0"
  }
}